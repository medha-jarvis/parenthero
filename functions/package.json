{
  "name": "parenthero-functions",
  "description": "Cloud Functions for ParentHero",
  "version": "1.0.0",
  "main": "lib/index.js",
  "scripts": {
    "lint": "eslint --ext .ts .",
    "build": "tsc",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "20"
  },
  "dependencies": {
    "firebase-admin": "^12.6.0",
    "firebase-functions": "^6.0.1",
    "stripe": "^17.2.1",
    "razorpay": "^2.9.5",
    "cors": "^2.8.5",
    "pdfkit": "^0.15.1",
    "express": "^4.21.1"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "eslint": "^8.57.1",
    "@types/express": "^5.0.0",
    "@types/cors": "^2.8.17",
    "@types/pdfkit": "^0.13.8"
  },
  "private": true
}
